<Window x:Class="IptvViewer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vlc="clr-namespace:LibVLCSharp.WPF;assembly=LibVLCSharp.WPF"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="IPTV Viewer"
        MinHeight="760"
        MinWidth="1080"
        Height="860"
        Width="1220"
        Background="#F6F7F9">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#18212F"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="0,6,0,14"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderBrush" Value="#C9D1DD"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style TargetType="PasswordBox">
            <Setter Property="Margin" Value="0,6,0,14"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderBrush" Value="#C9D1DD"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Margin" Value="0,0,8,8"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="MinHeight" Value="36"/>
            <Setter Property="Background" Value="#1F6FEB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style x:Key="CompactVideoButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Width" Value="40"/>
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Background" Value="#505A66"/>
        </Style>
        <Style x:Key="IconVideoButton" TargetType="Button" BasedOn="{StaticResource CompactVideoButton}">
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#D8DEE8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#EDF0F4"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
        </Style>
    </Window.Resources>

    <Grid x:Name="ShellGrid" Margin="24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="LeftColumn" Width="330"/>
            <ColumnDefinition x:Name="SpacerColumn" Width="24"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border x:Name="LeftPanel"
                Grid.Column="0"
                Background="White"
                BorderBrush="#D8DEE8"
                BorderThickness="1"
                CornerRadius="8"
                Padding="20">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="IPTV Test Browser"
                               FontSize="24"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"/>
                    <TextBlock Text="Saved services, local cache, favorites, history, and searchable IPTV lists."
                               TextWrapping="Wrap"
                               Foreground="#5A6574"
                               Margin="0,0,0,22"/>

                    <TextBlock Text="Saved Service" FontWeight="SemiBold"/>
                    <ComboBox x:Name="ServicesComboBox"
                              DisplayMemberPath="Name"
                              SelectionChanged="ServicesComboBox_SelectionChanged"
                              Margin="0,6,0,14"
                              Padding="8,6"/>

                    <TextBlock Text="Account Name" FontWeight="SemiBold"/>
                    <TextBox x:Name="AccountNameTextBox"
                             ToolTip="Example: My IPTV Service"/>

                    <TextBlock Text="Server URL" FontWeight="SemiBold"/>
                    <TextBox x:Name="ServerUrlTextBox"
                             ToolTip="Example: http://example.com:8080"/>

                    <TextBlock Text="Username" FontWeight="SemiBold"/>
                    <TextBox x:Name="UsernameTextBox"/>

                    <TextBlock Text="Password" FontWeight="SemiBold"/>
                    <PasswordBox x:Name="PasswordInput"/>

                    <UniformGrid Columns="1">
                        <Button x:Name="SaveServiceButton"
                                Content="Save Service"
                                Click="SaveServiceButton_Click"/>
                        <Button x:Name="LoadCacheButton"
                                Content="Load Local Cache"
                                Click="LoadCacheButton_Click"/>
                        <Button x:Name="RefreshCacheButton"
                                Content="Refresh All Lists (Slow)"
                                Click="RefreshCacheButton_Click"/>
                        <Button x:Name="RefreshLiveButton"
                                Content="Refresh Live Only"
                                Click="RefreshLiveButton_Click"/>
                        <Button x:Name="RefreshMoviesButton"
                                Content="Refresh Movies Only"
                                Click="RefreshMoviesButton_Click"/>
                        <Button x:Name="RefreshSeriesButton"
                                Content="Refresh Series Only"
                                Click="RefreshSeriesButton_Click"/>
                        <Button x:Name="RefreshGuideButton"
                                Content="Refresh TV Guide"
                                Margin="0,0,0,16"
                                Click="RefreshGuideButton_Click"/>
                    </UniformGrid>

                    <TextBlock Text="Local Files"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Margin="0,6,0,10"/>
                    <UniformGrid Columns="1">
                        <Button x:Name="ShowContinueWatchingButton"
                                Content="Show Continue Watching"
                                Click="ShowContinueWatchingButton_Click"/>
                        <Button x:Name="ShowFavoritesButton"
                                Content="Show Favorites"
                                Click="ShowFavoritesButton_Click"/>
                        <Button x:Name="ShowHistoryButton"
                                Content="Show History"
                                Click="ShowHistoryButton_Click"/>
                        <Button x:Name="RemoveFavoriteButton"
                                Content="Remove Favorite"
                                Background="#A1420A"
                                IsEnabled="False"
                                Click="RemoveFavoriteButton_Click"/>
                        <Button x:Name="ClearHistoryButton"
                                Content="Clear History"
                                Background="#A1420A"
                                Click="ClearHistoryButton_Click"/>
                        <Button x:Name="ExportDataButton"
                                Content="Export Saved Data"
                                Background="#505A66"
                                Click="ExportDataButton_Click"/>
                        <Button x:Name="ImportDataButton"
                                Content="Import Saved Data"
                                Background="#505A66"
                                Margin="0,0,0,16"
                                Click="ImportDataButton_Click"/>
                    </UniformGrid>

                    <TextBlock Text="Single Endpoint"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Margin="0,6,0,10"/>
                    <UniformGrid Columns="1">
                        <Button Content="Live Categories"
                                Tag="get_live_categories"
                                Click="EndpointButton_Click"/>
                        <Button Content="Live Streams / Channels"
                                Tag="get_live_streams"
                                Click="EndpointButton_Click"/>
                        <Button Content="VOD Categories"
                                Tag="get_vod_categories"
                                Click="EndpointButton_Click"/>
                        <Button Content="VOD Streams"
                                Tag="get_vod_streams"
                                Click="EndpointButton_Click"/>
                        <Button Content="Series Categories"
                                Tag="get_series_categories"
                                Click="EndpointButton_Click"/>
                        <Button Content="Series"
                                Tag="get_series"
                                Click="EndpointButton_Click"/>
                    </UniformGrid>

                    <TextBlock Text="Status"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Margin="0,18,0,8"/>
                    <TextBlock x:Name="StatusTextBlock"
                               Text="Ready."
                               Foreground="#5A6574"
                               TextWrapping="Wrap"/>
                    <TextBlock Text="Powered by JTMtechs.com"
                               Foreground="#7A8491"
                               FontSize="12"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               Margin="0,22,0,0"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition x:Name="HeaderRow" Height="Auto"/>
                <RowDefinition x:Name="PlayerRow" Height="360"/>
                <RowDefinition x:Name="ControlsRow" Height="Auto"/>
                <RowDefinition x:Name="SearchRow" Height="Auto"/>
                <RowDefinition x:Name="ResultsRow" Height="*"/>
            </Grid.RowDefinitions>

            <DockPanel x:Name="HeaderPanel" Grid.Row="0" LastChildFill="True" Margin="0,0,0,12">
                <TextBlock x:Name="ResultCountTextBlock"
                           DockPanel.Dock="Right"
                           Text="0 items"
                           VerticalAlignment="Center"
                           Foreground="#5A6574"/>
                <Border DockPanel.Dock="Left"
                        Width="58"
                        Height="58"
                        Background="#E8EDF3"
                        BorderBrush="#D8DEE8"
                        BorderThickness="1"
                        CornerRadius="6"
                        Margin="0,0,12,0">
                    <Image x:Name="SelectedArtworkImage"
                           Stretch="UniformToFill"/>
                </Border>
                <TextBlock Text="Results"
                           FontSize="24"
                           FontWeight="SemiBold"/>
                <TextBlock x:Name="SelectedDetailsTextBlock"
                           Text=""
                           VerticalAlignment="Bottom"
                           Margin="12,0,0,4"
                           Foreground="#5A6574"
                           TextTrimming="CharacterEllipsis"/>
            </DockPanel>

            <Border x:Name="PlayerSurface"
                    Grid.Row="1"
                    Background="#101418"
                    BorderBrush="#D8DEE8"
                    BorderThickness="1"
                    CornerRadius="8"
                    ClipToBounds="True"
                    Margin="0,0,0,12"
                    PreviewMouseDown="PlayerSurface_PreviewMouseDown"
                    MouseRightButtonUp="PlayerSurface_MouseRightButtonUp"
                    MouseMove="PlayerSurface_MouseMove">
                <Grid>
                    <vlc:VideoView x:Name="VideoPlayerView"/>
                    <TextBlock x:Name="PlayerPlaceholderTextBlock"
                               Text="Select a live channel, VOD movie, series, or episode, then press Play."
                               Foreground="#DDE3EA"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               TextWrapping="Wrap"
                               Margin="20"/>
                </Grid>
            </Border>

            <Popup x:Name="VideoOverlayPopup"
                   PlacementTarget="{Binding ElementName=PlayerSurface}"
                   Placement="Relative"
                   AllowsTransparency="True"
                   StaysOpen="False"
                   Closed="VideoOverlayPopup_Closed">
                <Border Padding="14"
                        CornerRadius="8"
                        Background="#E6101418"
                        BorderBrush="#66717F"
                        BorderThickness="1">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Volume"
                                   Foreground="#F6F7F9"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>
                        <Slider x:Name="OverlayVolumeSlider"
                                Width="150"
                                Minimum="0"
                                Maximum="100"
                                Value="80"
                                TickFrequency="10"
                                VerticalAlignment="Center"
                                ValueChanged="VolumeSlider_ValueChanged"
                                PreviewMouseDown="VideoOverlayControl_PreviewMouseDown"
                                PreviewMouseUp="VideoOverlayControl_PreviewMouseUp"
                                ToolTip="Volume"/>
                        <Button x:Name="OverlayPauseButton"
                                Content="&#xE769;"
                                Background="#505A66"
                                FontFamily="Segoe MDL2 Assets"
                                Margin="12,0,8,0"
                                Padding="10,6"
                                MinHeight="30"
                                Click="PauseButton_Click"/>
                        <TextBlock Text="Screen"
                                   Foreground="#F6F7F9"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Margin="4,0,8,0"/>
                        <ComboBox x:Name="OverlayScreenSelector"
                                  Width="120"
                                  SelectionChanged="OverlayScreenSelector_SelectionChanged"
                                  DropDownOpened="VideoOverlayControl_Active"
                                  DropDownClosed="VideoOverlayControl_Done">
                            <ComboBoxItem Content="25%" Tag="25"/>
                            <ComboBoxItem Content="50%" Tag="50"/>
                            <ComboBoxItem Content="Full Video" Tag="full"/>
                            <ComboBoxItem Content="Fullscreen" Tag="fullscreen"/>
                        </ComboBox>
                    </StackPanel>
                </Border>
            </Popup>

            <Grid Grid.Row="2" Margin="0,0,0,12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" LastChildFill="True">
                    <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                    <Button x:Name="PlayButton"
                            Content="&#xE768;"
                            Style="{StaticResource IconVideoButton}"
                            ToolTip="Play selected"
                            IsEnabled="False"
                            Click="PlayButton_Click"/>
                    <Button x:Name="PauseButton"
                            Content="&#xE769;"
                            Style="{StaticResource IconVideoButton}"
                            IsEnabled="False"
                            ToolTip="Pause or resume"
                            Click="PauseButton_Click"/>
                    <Button x:Name="RewindButton"
                            Content="-30s"
                            Style="{StaticResource CompactVideoButton}"
                            ToolTip="Rewind 30 seconds when the stream supports seeking"
                            IsEnabled="False"
                            Click="RewindButton_Click"/>
                    <Button x:Name="StopButton"
                            Content="&#xE71A;"
                            Style="{StaticResource IconVideoButton}"
                            ToolTip="Stop playback"
                            IsEnabled="False"
                            Click="StopButton_Click"/>
                    <Button x:Name="OverlayControlsButton"
                            Content="&#xE713;"
                            Style="{StaticResource IconVideoButton}"
                            ToolTip="Show video controls"
                            Click="OverlayControlsButton_Click"/>
                    <Button x:Name="Video25Button"
                            Content="25%"
                            Style="{StaticResource CompactVideoButton}"
                            ToolTip="Show video at 25 percent of the content area"
                            Click="Video25Button_Click"/>
                    <Button x:Name="Video50Button"
                            Content="50%"
                            Style="{StaticResource CompactVideoButton}"
                            ToolTip="Show video at 50 percent of the content area"
                            Click="Video50Button_Click"/>
                    <Button x:Name="FullVideoButton"
                            Content="▣"
                            Style="{StaticResource CompactVideoButton}"
                            ToolTip="Full video view inside the app"
                            Click="FullVideoButton_Click"/>
                    <Button x:Name="FullScreenButton"
                            Content="⛶"
                            Style="{StaticResource CompactVideoButton}"
                            ToolTip="Fullscreen video"
                            Click="FullScreenButton_Click"/>
                    <Button x:Name="AddFavoriteButton"
                            Content="Add Favorite"
                            Background="#188038"
                            IsEnabled="False"
                            Click="AddFavoriteButton_Click"/>
                    </StackPanel>
                    <TextBlock x:Name="NowPlayingTextBlock"
                               Text="Nothing playing."
                               VerticalAlignment="Center"
                               Foreground="#5A6574"
                               TextTrimming="CharacterEllipsis"/>
                </DockPanel>

                <Grid Grid.Row="1" Margin="0,4,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="48"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="48"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="PlaybackPositionTextBlock"
                               Text="0:00"
                               VerticalAlignment="Center"
                               Foreground="#5A6574"/>
                    <Slider x:Name="PlaybackPositionSlider"
                            Grid.Column="1"
                            Minimum="0"
                            Maximum="100"
                            IsEnabled="False"
                            ValueChanged="PlaybackPositionSlider_ValueChanged"
                            PreviewMouseDown="PlaybackPositionSlider_PreviewMouseDown"
                            PreviewMouseUp="PlaybackPositionSlider_PreviewMouseUp"/>
                    <TextBlock x:Name="PlaybackLengthTextBlock"
                               Grid.Column="2"
                               Text="0:00"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"
                               Foreground="#5A6574"/>
                </Grid>
            </Grid>

            <DockPanel x:Name="BrowseFilterPanel"
                       Grid.Row="3"
                       LastChildFill="True"
                       Margin="0,0,0,12">
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" Margin="0,0,8,0">
                    <Button Content="Home"
                            Tag="home"
                            Background="#505A66"
                            Click="BrowseTabButton_Click"/>
                    <Button Content="Live"
                            Tag="live"
                            Background="#505A66"
                            Click="BrowseTabButton_Click"/>
                    <Button Content="Movies"
                            Tag="vod"
                            Background="#505A66"
                            Click="BrowseTabButton_Click"/>
                    <Button Content="Series"
                            Tag="series"
                            Background="#505A66"
                            Click="BrowseTabButton_Click"/>
                    <Button Content="Guide"
                            Tag="guide"
                            Background="#505A66"
                            Click="BrowseTabButton_Click"/>
                </StackPanel>
                <ComboBox x:Name="CategoryFilterComboBox"
                          DockPanel.Dock="Right"
                          Width="210"
                          DisplayMemberPath="Name"
                          SelectedValuePath="Id"
                          SelectionChanged="CategoryFilterComboBox_SelectionChanged"
                          Margin="8,0,0,0"/>
                <TextBox x:Name="SearchTextBox"
                         Margin="0"
                         TextChanged="SearchTextBox_TextChanged"
                         ToolTip="Search by name, endpoint, category, stream id, artwork, or file extension"/>
            </DockPanel>

            <DockPanel x:Name="HomeFilterPanel"
                       Grid.Row="3"
                       LastChildFill="True"
                       Margin="0,0,0,12">
                <TextBlock Text="Type"
                           DockPanel.Dock="Left"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"/>
                <ComboBox x:Name="HomeTypeFilterComboBox"
                          Width="160"
                          DockPanel.Dock="Left"
                          SelectionChanged="HomeTypeFilterComboBox_SelectionChanged">
                    <ComboBoxItem Content="All" Tag="all"/>
                    <ComboBoxItem Content="Live" Tag="live"/>
                    <ComboBoxItem Content="VOD" Tag="vod"/>
                    <ComboBoxItem Content="Series" Tag="series"/>
                </ComboBox>
            </DockPanel>

            <Grid x:Name="HomePanel" Grid.Row="4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="White"
                        BorderBrush="#D8DEE8"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="Favorites"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,8"/>
                        <DataGrid x:Name="FavoritesGrid"
                                  Grid.Row="1"
                                  ItemsSource="{Binding FavoritesHome}"
                                  SelectionChanged="HomeGrid_SelectionChanged"
                                  MouseDoubleClick="PlayableGrid_MouseDoubleClick">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Service" Binding="{Binding ServiceName}" Width="95"/>
                                <DataGridTextColumn Header="Type" Binding="{Binding EndpointLabel}" Width="130"/>
                                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="2*"/>
                                <DataGridTextColumn Header="Saved" Binding="{Binding SavedAt}" Width="145"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

                <Border Grid.Row="2"
                        Background="White"
                        BorderBrush="#D8DEE8"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="History"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,8"/>
                        <DataGrid x:Name="HistoryGrid"
                                  Grid.Row="1"
                                  ItemsSource="{Binding HistoryHome}"
                                  SelectionChanged="HomeGrid_SelectionChanged"
                                  MouseDoubleClick="PlayableGrid_MouseDoubleClick">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Service" Binding="{Binding ServiceName}" Width="95"/>
                                <DataGridTextColumn Header="Type" Binding="{Binding EndpointLabel}" Width="130"/>
                                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="2*"/>
                                <DataGridTextColumn Header="Played" Binding="{Binding SavedAt}" Width="145"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </Grid>

            <DataGrid x:Name="ResultsGrid"
                      Grid.Row="4"
                      Visibility="Collapsed"
                      ItemsSource="{Binding ResultsView}"
                      SelectionChanged="ResultsGrid_SelectionChanged"
                      MouseDoubleClick="PlayableGrid_MouseDoubleClick">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Service" Binding="{Binding ServiceName}" Width="95"/>
                    <DataGridTextColumn Header="List" Binding="{Binding LocalList}" Width="85"/>
                    <DataGridTextColumn Header="Saved/Played" Binding="{Binding SavedAt}" Width="140"/>
                    <DataGridTextColumn Header="Endpoint" Binding="{Binding EndpointLabel}" Width="170"/>
                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="2*"/>
                    <DataGridTextColumn Header="Category Id" Binding="{Binding CategoryId}" Width="120"/>
                    <DataGridTextColumn Header="EPG Id" Binding="{Binding EpgChannelId}" Width="120"/>
                    <DataGridTextColumn Header="Now" Binding="{Binding CurrentProgram}" Width="190"/>
                    <DataGridTextColumn Header="Next" Binding="{Binding NextProgram}" Width="190"/>
                    <DataGridTextColumn Header="Item Id" Binding="{Binding ItemId}" Width="100"/>
                    <DataGridTextColumn Header="Extension" Binding="{Binding ContainerExtension}" Width="95"/>
                    <DataGridTextColumn Header="Artwork" Binding="{Binding ArtworkUrl}" Width="2*"/>
                    <DataGridTextColumn Header="Stream URL" Binding="{Binding PlaybackUrl}" Width="3*"/>
                </DataGrid.Columns>
            </DataGrid>

            <DataGrid x:Name="GuideGrid"
                      Grid.Row="4"
                      Visibility="Collapsed"
                      ItemsSource="{Binding EpgView}"
                      MouseDoubleClick="GuideGrid_MouseDoubleClick">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Channel" Binding="{Binding ChannelId}" Width="170"/>
                    <DataGridTextColumn Header="Program" Binding="{Binding Title}" Width="2*"/>
                    <DataGridTextColumn Header="Start" Binding="{Binding StartDisplay}" Width="145"/>
                    <DataGridTextColumn Header="Stop" Binding="{Binding StopDisplay}" Width="145"/>
                    <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="3*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</Window>
