<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="IptvViewer.MainWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:vlc="clr-namespace:LibVLCSharp.WPF;assembly=LibVLCSharp.WPF" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="d" Title="JTN IPTV Viewer" Icon="Assets/AppIcon.ico" MinHeight="760" MinWidth="1080" Height="860" Width="1220" Background="#07111F">
  <Window.Resources>
    <SolidColorBrush x:Key="AppBackgroundBrush" Color="#07111F" />
    <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#0E1A2B" />
    <SolidColorBrush x:Key="PanelAltBackgroundBrush" Color="#132238" />
    <SolidColorBrush x:Key="PanelBorderBrush" Color="#223A5A" />
    <SolidColorBrush x:Key="PrimaryTextBrush" Color="#F4F8FC" />
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="#AEBED0" />
    <SolidColorBrush x:Key="AccentBrush" Color="#007BFF" />
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#0069D9" />
    <SolidColorBrush x:Key="DangerBrush" Color="#DC3545" />
    <SolidColorBrush x:Key="InfoButtonBrush" Color="#17A2B8" />
    <SolidColorBrush x:Key="InfoButtonHoverBrush" Color="#138496" />
    <SolidColorBrush x:Key="NeutralButtonBrush" Color="#17A2B8" />
    <Style TargetType="TextBlock">
      <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
    </Style>
    <Style TargetType="TextBox">
      <Setter Property="Margin" Value="0,6,0,14" />
      <Setter Property="Padding" Value="10,8" />
      <Setter Property="Background" Value="#F7FAFD" />
      <Setter Property="Foreground" Value="#0E1726" />
      <Setter Property="BorderBrush" Value="#5C718C" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style TargetType="PasswordBox">
      <Setter Property="Margin" Value="0,6,0,14" />
      <Setter Property="Padding" Value="10,8" />
      <Setter Property="Background" Value="#F7FAFD" />
      <Setter Property="Foreground" Value="#0E1726" />
      <Setter Property="BorderBrush" Value="#5C718C" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style TargetType="ComboBox">
      <Setter Property="Background" Value="#F7FAFD" />
      <Setter Property="Foreground" Value="#0E1726" />
      <Setter Property="BorderBrush" Value="#5C718C" />
    </Style>
    <Style TargetType="Button">
      <Setter Property="Margin" Value="0,0,0,6" />
      <Setter Property="Padding" Value="10,6" />
      <Setter Property="MinHeight" Value="32" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Background" Value="{StaticResource AccentBrush}" />
      <Setter Property="Foreground" Value="White" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Cursor" Value="Hand" />
    </Style>
    <Style x:Key="SliderTrackButton" TargetType="{x:Type RepeatButton}">
      <Setter Property="Focusable" Value="False" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="{x:Type RepeatButton}">
            <Border Height="6" Background="{TemplateBinding Background}" CornerRadius="3" />
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
    <Style x:Key="ModernSliderThumb" TargetType="{x:Type Thumb}">
      <Setter Property="Width" Value="16" />
      <Setter Property="Height" Value="16" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="{x:Type Thumb}">
            <Border Background="White" BorderBrush="{StaticResource AccentBrush}" BorderThickness="2" CornerRadius="8" />
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
    <Style TargetType="Slider">
      <Setter Property="Height" Value="24" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="{x:Type Slider}">
            <Grid VerticalAlignment="Center">
              <Track x:Name="PART_Track" VerticalAlignment="Center">
                <Track.DecreaseRepeatButton>
                  <RepeatButton Command="Slider.DecreaseLarge" Style="{StaticResource SliderTrackButton}" Background="{StaticResource AccentBrush}" />
                </Track.DecreaseRepeatButton>
                <Track.Thumb>
                  <Thumb Style="{StaticResource ModernSliderThumb}" />
                </Track.Thumb>
                <Track.IncreaseRepeatButton>
                  <RepeatButton Command="Slider.IncreaseLarge" Style="{StaticResource SliderTrackButton}" Background="#314866" />
                </Track.IncreaseRepeatButton>
              </Track>
            </Grid>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
    <Style x:Key="CompactVideoButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
      <Setter Property="Margin" Value="0,0,6,6" />
      <Setter Property="Width" Value="40" />
      <Setter Property="MinHeight" Value="32" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Background" Value="#F8F9FA" />
      <Setter Property="Foreground" Value="#0B1C2F" />
    </Style>
    <Style x:Key="IconVideoButton" TargetType="Button" BasedOn="{StaticResource CompactVideoButton}">
      <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
      <Setter Property="FontSize" Value="14" />
    </Style>
    <Style TargetType="DataGrid">
      <Setter Property="Background" Value="#F8FAFC" />
      <Setter Property="Foreground" Value="#102033" />
      <Setter Property="BorderBrush" Value="#314866" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="GridLinesVisibility" Value="Horizontal" />
      <Setter Property="HorizontalGridLinesBrush" Value="#DCE4EE" />
      <Setter Property="RowHeaderWidth" Value="0" />
      <Setter Property="AutoGenerateColumns" Value="False" />
      <Setter Property="CanUserAddRows" Value="False" />
      <Setter Property="IsReadOnly" Value="True" />
    </Style>
  </Window.Resources>
  <Grid x:Name="ShellGrid" Margin="24">
    <Grid.ColumnDefinitions>
      <ColumnDefinition x:Name="LeftColumn" Width="330" />
      <ColumnDefinition x:Name="SpacerColumn" Width="24" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>
    <Border x:Name="LeftPanel" Grid.Column="0" Background="{StaticResource PanelBackgroundBrush}" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="20">
      <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
          <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,6">
            <TextBlock Text="IP" FontSize="25" FontWeight="Bold" Foreground="#2F6BFF" VerticalAlignment="Center" />
            <TextBlock Text="TV" FontSize="25" FontWeight="Bold" Foreground="White" VerticalAlignment="Center" />
            <TextBlock Text=" (JTNTechs.com)" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource SecondaryTextBrush}" VerticalAlignment="Center" Margin="6,0,0,0" />
          </StackPanel>
          <TextBlock Text="Saved services, local cache, favorites, history, and searchable IPTV lists." TextWrapping="Wrap" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,0,22" />
          <TextBlock Text="Saved Service" FontWeight="SemiBold" />
          <StackPanel Margin="10,6,10,12">
            <ComboBox x:Name="ServicesComboBox" DisplayMemberPath="Name" SelectionChanged="ServicesComboBox_SelectionChanged" Padding="8,6" Margin="0,0,0,8" />
            <UniformGrid Columns="2">
              <Button x:Name="EditServiceButton" Content="Edit" Margin="0,0,6,6" Click="EditServiceButton_Click" />
              <Button x:Name="AddServiceButton" Content="Add" Margin="6,0,0,6" Click="AddServiceButton_Click" />
            </UniformGrid>
          </StackPanel>
          <Border x:Name="ServiceEditorPanel" Visibility="Collapsed" Background="{StaticResource PanelAltBackgroundBrush}" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,14">
            <StackPanel>
              <TextBlock Text="Account Name" FontWeight="SemiBold" />
              <TextBox x:Name="AccountNameTextBox" Text="" />
              <TextBlock Text="Server URL" FontWeight="SemiBold" />
              <TextBox x:Name="ServerUrlTextBox" Text="" ToolTip="Example: http://example.com:8080" />
              <TextBlock Text="Username" FontWeight="SemiBold" />
              <TextBox x:Name="UsernameTextBox" Text="" />
              <TextBlock Text="Password" FontWeight="SemiBold" />
              <PasswordBox x:Name="PasswordInput" />
              <StackPanel Orientation="Horizontal">
                <Button x:Name="SaveServiceButton" Content="Save Service" Margin="0,0,8,6" Click="SaveServiceButton_Click" />
                <Button x:Name="CancelServiceEditButton" Content="Cancel" Background="{StaticResource NeutralButtonBrush}" Click="CancelServiceEditButton_Click" />
              </StackPanel>
            </StackPanel>
          </Border>
          <UniformGrid Columns="1" Margin="10,0,10,0">
            <Button x:Name="LoadCacheButton" Content="Load Local Cache" Click="LoadCacheButton_Click" />
            <Button x:Name="RefreshCacheButton" Content="Refresh All Lists (Slow)" Click="RefreshCacheButton_Click" />
            <Button x:Name="RefreshLiveButton" Content="Refresh Live Only" Click="RefreshLiveButton_Click" />
            <Button x:Name="RefreshMoviesButton" Content="Refresh Movies Only" Click="RefreshMoviesButton_Click" />
            <Button x:Name="RefreshSeriesButton" Content="Refresh Series Only" Click="RefreshSeriesButton_Click" />
            <Button x:Name="RefreshGuideButton" Content="Refresh TV Guide" Margin="0,0,0,16" Click="RefreshGuideButton_Click" />
          </UniformGrid>
          <TextBlock Text="Local Files" FontSize="16" FontWeight="SemiBold" Margin="0,6,0,10" />
          <UniformGrid Columns="1" Margin="10,0,10,0">
            <Button x:Name="ShowContinueWatchingButton" Content="Show Continue Watching" Click="ShowContinueWatchingButton_Click" />
            <Button x:Name="ShowFavoritesButton" Content="Show Favorites" Click="ShowFavoritesButton_Click" />
            <Button x:Name="ShowHistoryButton" Content="Show History" Click="ShowHistoryButton_Click" />
            <Button x:Name="RemoveFavoriteButton" Content="Remove Favorite" Background="{StaticResource DangerBrush}" IsEnabled="False" Click="RemoveFavoriteButton_Click" />
            <Button x:Name="ClearHistoryButton" Content="Clear History" Background="{StaticResource DangerBrush}" Click="ClearHistoryButton_Click" />
            <Button x:Name="ExportDataButton" Content="Export Saved Data" Background="{StaticResource NeutralButtonBrush}" Click="ExportDataButton_Click" />
            <Button x:Name="ImportDataButton" Content="Import Saved Data" Background="{StaticResource NeutralButtonBrush}" Margin="0,0,0,16" Click="ImportDataButton_Click" />
          </UniformGrid>
          <TextBlock Text="Single Endpoint" FontSize="16" FontWeight="SemiBold" Margin="0,6,0,10" />
          <UniformGrid Columns="1" Margin="10,0,10,0">
            <Button Content="Live Categories" Tag="get_live_categories" Click="EndpointButton_Click" />
            <Button Content="Live Streams / Channels" Tag="get_live_streams" Click="EndpointButton_Click" />
            <Button Content="VOD Categories" Tag="get_vod_categories" Click="EndpointButton_Click" />
            <Button Content="VOD Streams" Tag="get_vod_streams" Click="EndpointButton_Click" />
            <Button Content="Series Categories" Tag="get_series_categories" Click="EndpointButton_Click" />
            <Button Content="Series" Tag="get_series" Click="EndpointButton_Click" />
          </UniformGrid>
          <TextBlock Text="Status" FontSize="16" FontWeight="SemiBold" Margin="0,18,0,8" />
          <TextBlock x:Name="StatusTextBlock" Text="Ready." Foreground="{StaticResource SecondaryTextBrush}" TextWrapping="Wrap" />
          <Border Background="{StaticResource PanelAltBackgroundBrush}" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,22,0,0">
            <StackPanel>
              <TextBlock Text="About JTN Techs" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,6" />
              <TextBlock Text="Silver Spring and DC technology team focused on managed IT, cybersecurity, cloud infrastructure, legacy modernization, and custom .NET development. JTN Techs brings 20+ years of practical experience building secure systems that keep businesses moving." Foreground="{StaticResource SecondaryTextBrush}" TextWrapping="Wrap" />
              <Button Content="Visit jtntechs.com" Margin="0,12,0,0" Click="OpenPublisherWebsiteButton_Click" />
            </StackPanel>
          </Border>
          <TextBlock Text="Powered by JTNtechs.com" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,22,0,0" />
        </StackPanel>
      </ScrollViewer>
    </Border>
    <Grid Grid.Column="2">
      <Grid.RowDefinitions>
        <RowDefinition x:Name="HeaderRow" Height="Auto" />
        <RowDefinition x:Name="PlayerRow" Height="65*" />
        <RowDefinition x:Name="ControlsRow" Height="Auto" />
        <RowDefinition x:Name="SplitterRow" Height="6" />
        <RowDefinition x:Name="SearchRow" Height="Auto" />
        <RowDefinition x:Name="ResultsRow" Height="35*" />
      </Grid.RowDefinitions>
      <DockPanel x:Name="HeaderPanel" Grid.Row="0" LastChildFill="True" Margin="0,0,0,12">
        <TextBlock x:Name="ResultCountTextBlock" DockPanel.Dock="Right" Text="0 items" VerticalAlignment="Center" Foreground="{StaticResource SecondaryTextBrush}" />
        <Border DockPanel.Dock="Left" Width="66" Height="58" Background="White" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" CornerRadius="6" Padding="6" Margin="0,0,12,0">
          <Image x:Name="SelectedArtworkImage" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" SnapsToDevicePixels="True" />
        </Border>
        <TextBlock Text="Results" FontSize="24" FontWeight="SemiBold" />
        <TextBlock x:Name="SelectedDetailsTextBlock" Text="" VerticalAlignment="Bottom" Margin="12,0,0,4" Foreground="{StaticResource SecondaryTextBrush}" TextTrimming="CharacterEllipsis" />
      </DockPanel>
      <Border x:Name="PlayerSurface" Grid.Row="1" Background="#101418" BorderThickness="0" CornerRadius="0" ClipToBounds="True" Margin="0,0,0,12" PreviewMouseDown="PlayerSurface_PreviewMouseDown" MouseRightButtonUp="PlayerSurface_MouseRightButtonUp" MouseMove="PlayerSurface_MouseMove">
        <Grid>
          <vlc:VideoView x:Name="VideoPlayerView" />
          <TextBlock x:Name="PlayerPlaceholderTextBlock" Text="Select a live channel, VOD movie, series, or episode, then press Play." Foreground="#DDE3EA" HorizontalAlignment="Center" VerticalAlignment="Center" TextWrapping="Wrap" Margin="20" />
        </Grid>
      </Border>
      <Popup x:Name="VideoOverlayPopup" PlacementTarget="{Binding ElementName=PlayerSurface}" Placement="Relative" AllowsTransparency="True" StaysOpen="False" Closed="VideoOverlayPopup_Closed">
        <Border Padding="14" CornerRadius="8" Background="#E6101418" BorderBrush="#66717F" BorderThickness="1">
          <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <TextBlock Text="Volume" Foreground="#F6F7F9" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,8,0" />
            <Slider x:Name="OverlayVolumeSlider" Width="150" Minimum="0" Maximum="100" Value="80" TickFrequency="10" VerticalAlignment="Center" ValueChanged="VolumeSlider_ValueChanged" PreviewMouseDown="VideoOverlayControl_PreviewMouseDown" PreviewMouseUp="VideoOverlayControl_PreviewMouseUp" ToolTip="Volume" />
            <Button x:Name="OverlayPauseButton" Content="" Background="{StaticResource NeutralButtonBrush}" FontFamily="Segoe MDL2 Assets" Margin="12,0,8,0" Padding="10,6" MinHeight="30" Click="PauseButton_Click" />
            <TextBlock Text="Screen" Foreground="#F6F7F9" FontWeight="SemiBold" VerticalAlignment="Center" Margin="4,0,8,0" />
            <ComboBox x:Name="OverlayScreenSelector" Width="120" SelectionChanged="OverlayScreenSelector_SelectionChanged" DropDownOpened="VideoOverlayControl_Active" DropDownClosed="VideoOverlayControl_Done">
              <ComboBoxItem Content="Small" Tag="25" />
              <ComboBoxItem Content="Full Video" Tag="full" />
              <ComboBoxItem Content="Fullscreen" Tag="fullscreen" />
            </ComboBox>
          </StackPanel>
        </Border>
      </Popup>
      <Grid Grid.Row="2" Margin="0,0,0,12">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <DockPanel Grid.Row="0" LastChildFill="True">
          <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
            <Button x:Name="PlayButton" Content="" Style="{StaticResource IconVideoButton}" ToolTip="Play selected" IsEnabled="False" Click="PlayButton_Click" />
            <Button x:Name="PauseButton" Content="" Style="{StaticResource IconVideoButton}" IsEnabled="False" ToolTip="Pause or resume" Click="PauseButton_Click" />
            <Button x:Name="RewindButton" Content="-30s" Style="{StaticResource CompactVideoButton}" ToolTip="Rewind 30 seconds when the stream supports seeking" IsEnabled="False" Click="RewindButton_Click" />
            <Button x:Name="StopButton" Content="" Style="{StaticResource IconVideoButton}" ToolTip="Stop playback" IsEnabled="False" Click="StopButton_Click" />
            <Button x:Name="OverlayControlsButton" Content="" Style="{StaticResource IconVideoButton}" ToolTip="Show video controls" Click="OverlayControlsButton_Click" />
            <Button x:Name="Video25Button" Content="Small" Style="{StaticResource CompactVideoButton}" ToolTip="Default player and list view" Click="Video25Button_Click" Width="52" FontSize="11" />
            <Button x:Name="FullVideoButton" Content="FULL" Style="{StaticResource CompactVideoButton}" ToolTip="Full video view inside the app" Click="FullVideoButton_Click" Width="48" FontSize="11" />
            <Button x:Name="FullScreenButton" Content="IPTV" Style="{StaticResource CompactVideoButton}" ToolTip="Fullscreen video" Click="FullScreenButton_Click" Width="48" FontSize="11" />
            <Button x:Name="AddFavoriteButton" Content="Add Favorite" Background="#28A745" Margin="0,0,6,6" IsEnabled="False" Click="AddFavoriteButton_Click" />
          </StackPanel>
          <TextBlock x:Name="NowPlayingTextBlock" Text="Nothing playing." VerticalAlignment="Center" Foreground="{StaticResource SecondaryTextBrush}" TextTrimming="CharacterEllipsis" />
        </DockPanel>
        <Grid Grid.Row="1" Margin="0,4,0,0">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="48" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="48" />
          </Grid.ColumnDefinitions>
          <TextBlock x:Name="PlaybackPositionTextBlock" Text="0:00" VerticalAlignment="Center" Foreground="{StaticResource SecondaryTextBrush}" />
          <Slider x:Name="PlaybackPositionSlider" Grid.Column="1" Minimum="0" Maximum="100" IsEnabled="False" ValueChanged="PlaybackPositionSlider_ValueChanged" PreviewMouseDown="PlaybackPositionSlider_PreviewMouseDown" PreviewMouseUp="PlaybackPositionSlider_PreviewMouseUp" />
          <TextBlock x:Name="PlaybackLengthTextBlock" Grid.Column="2" Text="0:00" HorizontalAlignment="Right" VerticalAlignment="Center" Foreground="{StaticResource SecondaryTextBrush}" />
        </Grid>
      </Grid>
      <GridSplitter Grid.Row="3" Height="6" HorizontalAlignment="Stretch" VerticalAlignment="Center" Background="#223A5A" ResizeBehavior="BasedOnAlignment" ResizeDirection="Rows" DragDelta="PlayerListSplitter_DragDelta" />
      <DockPanel x:Name="BrowseFilterPanel" Grid.Row="4" LastChildFill="True" Margin="0,0,0,12">
        <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" Margin="0,0,8,0">
          <Button Content="Home" Tag="home" Background="{StaticResource NeutralButtonBrush}" Margin="0,0,6,6" Click="BrowseTabButton_Click" />
          <Button Content="Live" Tag="live" Background="{StaticResource NeutralButtonBrush}" Margin="0,0,6,6" Click="BrowseTabButton_Click" />
          <Button Content="Movies" Tag="vod" Background="{StaticResource NeutralButtonBrush}" Margin="0,0,6,6" Click="BrowseTabButton_Click" />
          <Button Content="Series" Tag="series" Background="{StaticResource NeutralButtonBrush}" Margin="0,0,6,6" Click="BrowseTabButton_Click" />
          <Button Content="Guide" Tag="guide" Background="{StaticResource NeutralButtonBrush}" Click="BrowseTabButton_Click" />
        </StackPanel>
        <ComboBox x:Name="CategoryFilterComboBox" DockPanel.Dock="Right" Width="210" DisplayMemberPath="Name" SelectedValuePath="Id" SelectionChanged="CategoryFilterComboBox_SelectionChanged" Margin="8,0,0,0" />
        <TextBox x:Name="SearchTextBox" Margin="0" TextChanged="SearchTextBox_TextChanged" ToolTip="Search by name, endpoint, category, stream id, artwork, or file extension" />
      </DockPanel>
      <DockPanel x:Name="HomeFilterPanel" Grid.Row="4" LastChildFill="True" Margin="0,0,0,12">
        <TextBlock Text="Type" DockPanel.Dock="Left" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,8,0" />
        <ComboBox x:Name="HomeTypeFilterComboBox" Width="160" DockPanel.Dock="Left" SelectionChanged="HomeTypeFilterComboBox_SelectionChanged">
          <ComboBoxItem Content="All" Tag="all" />
          <ComboBoxItem Content="Live" Tag="live" />
          <ComboBoxItem Content="VOD" Tag="vod" />
          <ComboBoxItem Content="Series" Tag="series" />
        </ComboBox>
      </DockPanel>
      <Grid x:Name="HomePanel" Grid.Row="5">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="12" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Border Grid.Column="0" Background="White" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="12">
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <TextBlock Text="★" FontSize="18" FontWeight="SemiBold" Foreground="#FFC107" Margin="0,0,0,8" ToolTip="Favorites" />
            <DataGrid x:Name="FavoritesGrid" Grid.Row="1" ItemsSource="{Binding FavoritesHome}" SelectionChanged="HomeGrid_SelectionChanged" MouseDoubleClick="PlayableGrid_MouseDoubleClick">
              <DataGrid.Columns>
                <DataGridTextColumn Header="Service" Binding="{Binding ServiceName}" Width="95" />
                <DataGridTextColumn Header="Type" Binding="{Binding EndpointLabel}" Width="130" />
                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="2*" />
              </DataGrid.Columns>
            </DataGrid>
          </Grid>
        </Border>
        <Border Grid.Column="2" Background="White" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="12">
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <TextBlock Text="📖" FontSize="16" FontWeight="SemiBold" Foreground="#6C757D" Margin="0,0,0,8" ToolTip="History" />
            <DataGrid x:Name="HistoryGrid" Grid.Row="1" ItemsSource="{Binding HistoryHome}" SelectionChanged="HomeGrid_SelectionChanged" MouseDoubleClick="PlayableGrid_MouseDoubleClick">
              <DataGrid.Columns>
                <DataGridTextColumn Header="Service" Binding="{Binding ServiceName}" Width="95" />
                <DataGridTextColumn Header="Type" Binding="{Binding EndpointLabel}" Width="130" />
                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="2*" />
              </DataGrid.Columns>
            </DataGrid>
          </Grid>
        </Border>
      </Grid>
      <DataGrid x:Name="ResultsGrid" Grid.Row="5" Visibility="Collapsed" ItemsSource="{Binding ResultsView}" SelectionChanged="ResultsGrid_SelectionChanged" MouseDoubleClick="PlayableGrid_MouseDoubleClick">
        <DataGrid.Columns>
          <DataGridTextColumn Header="Service" Binding="{Binding ServiceName}" Width="95" />
          <DataGridTextColumn Header="List" Binding="{Binding LocalList}" Width="85" />
          <DataGridTextColumn Header="Saved/Played" Binding="{Binding SavedAt}" Width="140" />
          <DataGridTextColumn Header="Endpoint" Binding="{Binding EndpointLabel}" Width="170" />
          <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="2*" />
          <DataGridTextColumn Header="Category Id" Binding="{Binding CategoryId}" Width="120" />
          <DataGridTextColumn Header="EPG Id" Binding="{Binding EpgChannelId}" Width="120" />
          <DataGridTextColumn Header="Now" Binding="{Binding CurrentProgram}" Width="190" />
          <DataGridTextColumn Header="Next" Binding="{Binding NextProgram}" Width="190" />
          <DataGridTextColumn Header="Item Id" Binding="{Binding ItemId}" Width="100" />
          <DataGridTextColumn Header="Extension" Binding="{Binding ContainerExtension}" Width="95" />
          <DataGridTextColumn Header="Artwork" Binding="{Binding ArtworkUrl}" Width="2*" />
          <DataGridTextColumn Header="Stream URL" Binding="{Binding PlaybackUrl}" Width="3*" />
        </DataGrid.Columns>
      </DataGrid>
      <DataGrid x:Name="GuideGrid" Grid.Row="5" Visibility="Collapsed" ItemsSource="{Binding EpgView}" MouseDoubleClick="GuideGrid_MouseDoubleClick">
        <DataGrid.Columns>
          <DataGridTextColumn Header="Channel" Binding="{Binding ChannelId}" Width="170" />
          <DataGridTextColumn Header="Program" Binding="{Binding Title}" Width="2*" />
          <DataGridTextColumn Header="Start" Binding="{Binding StartDisplay}" Width="145" />
          <DataGridTextColumn Header="Stop" Binding="{Binding StopDisplay}" Width="145" />
          <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="3*" />
        </DataGrid.Columns>
      </DataGrid>
    </Grid>
  </Grid>
</Window>
